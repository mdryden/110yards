{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "license": "",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "start": "sirv public -s",
    "deploy-test": "firebase deploy --only hosting",
    "format": "prettier --check src/**/*.{js,svelte}",
    "predeploy-test": "yarn build --mode test",
    "test": "jest --detectOpenHandles --testPathIgnorePatterns=.*/ui/.* --passWithNoTests",
    "testAll": "jest --detectOpenHandles",
    "ui-test": "jest --detectOpenHandles --testPathPatterns=.*/ui/.*"
  },
  "dependencies": {
    "firebase": "^8.2.1",
    "sirv-cli": "^1.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^16.0.0",
    "@rollup/plugin-node-resolve": "^10.0.0",
    "@rollup/plugin-replace": "^2.3.4",
    "@rollup/plugin-typescript": "^8.1.0",
    "@tsconfig/svelte": "^1.0.10",
    "@types/page": "^1.11.0",
    "dotenv": "^8.2.0",
    "jest": "^24.9.0",
    "jest-environment-webdriver": "^0.2.0",
    "page": "^1.11.6",
    "prettier-plugin-svelte": "^1.4.2",
    "rollup": "^2.3.4",
    "rollup-plugin-css-only": "^3.1.0",
    "rollup-plugin-livereload": "^2.0.0",
    "rollup-plugin-svelte": "^7.0.0",
    "rollup-plugin-terser": "^7.0.0",
    "selenium-webdriver": "^4.0.0-alpha.5",
    "svelte": "^3.0.0",
    "svelte-check": "^1.1.23",
    "svelte-preprocess": "^4.6.1",
    "typescript": "^4.1.3"
  }
}
